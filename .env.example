# Kalshi API Credentials
# Get from: https://kalshi.com/account/api
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_EMAIL=your_kalshi_email_here
KALSHI_PASSWORD=your_kalshi_password_here

# Polymarket API (optional - public endpoints available)
# Get from: https://docs.polymarket.com/
POLYMARKET_API_KEY=optional_for_rate_limits

# PostgreSQL Database
# Option 1: single URL (recommended for cloud platforms like Heroku, Railway, Render)
DATABASE_URL=postgresql+psycopg2://postgres:yourpassword@localhost:5432/arbitrage_db

# Option 2: individual vars (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=arbitrage_db

# Application Settings
POLL_INTERVAL_SECONDS=60
FEE_KALSHI=0.07
FEE_POLYMARKET=0.02
MIN_SPREAD_THRESHOLD=0.05
FUZZY_MATCH_THRESHOLD=85
BAYESIAN_WINDOW_SIZE=10

# Flask API
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True

# Logging
LOG_LEVEL=INFO
